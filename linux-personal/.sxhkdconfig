XF86MonBrightnessDown
    brightnessctl set 5%-

XF86MonBrightnessUp
    brightnessctl set +5%

XF86AudioRaiseVolume
    wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 ; \
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+

XF86AudioLowerVolume
    wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 ; \
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
