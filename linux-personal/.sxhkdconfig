XF86MonBrightnessDown
    brightnessctl set 5%-

XF86MonBrightnessUp
    brightnessctl set +5%

XF86AudioRaiseVolume
    amixer sset Master unmute ; \
    amixer sset Master 5%+

XF86AudioLowerVolume
    amixer sset Master unmute ; \
    amixer sset Master 5%-

XF86AudioMute
    amixer sset Master toggle

# Print = PrtSc F9 on ThinkPad E14
Print
    scrot -F ~/downloads/"$(date)".jpg

shift + Print
    scrot -u -F ~/downloads/"$(date)".jpg
